# Docker Compose optional overrides
# Copy to .env if you want to customize these values before `docker compose up -d`.
# Docker Compose reads DEEPSEEK_API_KEY from the host environment or this .env file.

# Optional image mirrors. Defaults are selected for a smoother first deploy on
# networks where Docker Hub is unstable; override these if your environment uses
# a private registry or a different mirror.
MYSQL_IMAGE=public.ecr.aws/docker/library/mysql:8.0
REDIS_IMAGE=public.ecr.aws/docker/library/redis:7-alpine
NACOS_IMAGE=nacos/nacos-server:v2.4.2
MINIO_IMAGE=quay.io/minio/minio:latest
MAVEN_IMAGE=public.ecr.aws/docker/library/maven:3.9.9-eclipse-temurin-17
JAVA_RUNTIME_IMAGE=public.ecr.aws/docker/library/eclipse-temurin:17-jre
NODE_IMAGE=public.ecr.aws/docker/library/node:20-alpine
NGINX_IMAGE=public.ecr.aws/docker/library/nginx:1.27-alpine

DEEPSEEK_API_KEY=

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=root
MINIO_SECRET_KEY=12345678
MINIO_BUCKET=activity-images
MINIO_PUBLIC_BASE_URL=/api

# Optional MCP server setting
CLOUD_DEMO_API_BASE_URL=http://127.0.0.1:9000
