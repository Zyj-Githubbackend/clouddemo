# Docker Compose optional overrides
# Copy to .env if you want to customize these values before `docker compose up -d`.
# Docker Compose reads DEEPSEEK_API_KEY from the host environment or this .env file.

# Optional image mirrors. Defaults are selected for a smoother first deploy on
# networks where Docker Hub is unstable; override these if your environment uses
# a private registry or a different mirror.
MYSQL_IMAGE=public.ecr.aws/docker/library/mysql:8.0
REDIS_IMAGE=public.ecr.aws/docker/library/redis:7-alpine
NACOS_IMAGE=nacos/nacos-server:v2.4.2
MINIO_IMAGE=quay.io/minio/minio:latest
MAVEN_IMAGE=public.ecr.aws/docker/library/maven:3.9.9-eclipse-temurin-17
JAVA_RUNTIME_IMAGE=public.ecr.aws/docker/library/eclipse-temurin:17-jre
NODE_IMAGE=public.ecr.aws/docker/library/node:20-alpine
NGINX_IMAGE=public.ecr.aws/docker/library/nginx:1.27-alpine
RABBITMQ_IMAGE=rabbitmq:3.13-management-alpine

DEEPSEEK_API_KEY=

MYSQL_ROOT_PASSWORD=123888
MYSQL_MAX_CONNECTIONS=500

USER_SERVICE_DB_URL=jdbc:mysql://mysql:3306/user_service_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
USER_SERVICE_DB_USERNAME=user_service
USER_SERVICE_DB_PASSWORD=123888
ACTIVITY_SERVICE_DB_URL=jdbc:mysql://mysql:3306/activity_service_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
ACTIVITY_SERVICE_DB_USERNAME=activity_service
ACTIVITY_SERVICE_DB_PASSWORD=123888
ANNOUNCEMENT_SERVICE_DB_URL=jdbc:mysql://mysql:3306/announcement_service_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
ANNOUNCEMENT_SERVICE_DB_USERNAME=announcement_service
ANNOUNCEMENT_SERVICE_DB_PASSWORD=123888
FEEDBACK_SERVICE_DB_URL=jdbc:mysql://mysql:3306/feedback_service_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
FEEDBACK_SERVICE_DB_USERNAME=feedback_service
FEEDBACK_SERVICE_DB_PASSWORD=123888
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# Gateway resilience defaults
GATEWAY_CONNECT_TIMEOUT_MS=3000
GATEWAY_RESPONSE_TIMEOUT=6s
GATEWAY_USER_REPLENISH_RATE=20
GATEWAY_USER_BURST_CAPACITY=40
GATEWAY_ACTIVITY_REPLENISH_RATE=40
GATEWAY_ACTIVITY_BURST_CAPACITY=80
GATEWAY_ANNOUNCEMENT_REPLENISH_RATE=40
GATEWAY_ANNOUNCEMENT_BURST_CAPACITY=80
GATEWAY_FEEDBACK_REPLENISH_RATE=20
GATEWAY_FEEDBACK_BURST_CAPACITY=40

# Core-link(user-service client) resilience defaults
USER_SERVICE_CONNECT_TIMEOUT=2s
USER_SERVICE_READ_TIMEOUT=3s
USER_SERVICE_CLIENT_LIMIT_FOR_PERIOD=100
USER_SERVICE_CLIENT_LIMIT_REFRESH_PERIOD=1s
USER_SERVICE_CLIENT_RATE_LIMIT_TIMEOUT=0s
USER_SERVICE_CLIENT_BULKHEAD_MAX_CONCURRENT_CALLS=30
USER_SERVICE_CLIENT_BULKHEAD_MAX_WAIT_DURATION=0

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=root
MINIO_SECRET_KEY=12345678
MINIO_BUCKET=activity-images
MINIO_PUBLIC_BASE_URL=/api

# Optional MCP server setting
CLOUD_DEMO_API_BASE_URL=http://127.0.0.1:9000
MCP_CLOUD_DEMO_API_BASE_URL=http://gateway-a:9000
MCP_MONITOR_SERVICE_URL=http://monitor-a:9100
MCP_SERVICE_BASE_URL=http://mcp-service:9300

# Edge
EDGE_HTTP_PORT=8081
