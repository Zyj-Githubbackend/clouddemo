# Docker Compose optional overrides
# Copy to .env if you want to customize these values before `docker compose up -d`.
# Docker Compose reads DEEPSEEK_API_KEY from the host environment or this .env file.

DEEPSEEK_API_KEY=

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=root
MINIO_SECRET_KEY=12345678
MINIO_BUCKET=activity-images
MINIO_PUBLIC_BASE_URL=/api

# Optional MCP server setting
CLOUD_DEMO_API_BASE_URL=http://127.0.0.1:9000
