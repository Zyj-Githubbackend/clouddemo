digraph ER {
  graph [rankdir=LR, bgcolor=white, pad=0.35, nodesep=0.55, ranksep=0.9, splines=true];
  node [shape=plain, fontname=Arial];
  edge [fontname=Arial, fontsize=10, color="#5D6D7E", arrowsize=0.7];
  labelloc="t";
  label="user-service";

  sys_user [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#6A7A89"><TR><TD BGCOLOR="#24415F" COLSPAN="3"><FONT COLOR="white"><B>sys_user</B></FONT></TD></TR><TR><TD PORT="id" ALIGN="LEFT"><B>id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">PK AI</FONT></TD></TR><TR><TD PORT="username" ALIGN="LEFT"><B>username</B></TD><TD ALIGN="LEFT">VARCHAR(50)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN UQ</FONT></TD></TR><TR><TD PORT="password" ALIGN="LEFT"><B>password</B></TD><TD ALIGN="LEFT">VARCHAR(255)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="real_name" ALIGN="LEFT"><B>real_name</B></TD><TD ALIGN="LEFT">VARCHAR(50)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="student_no" ALIGN="LEFT"><B>student_no</B></TD><TD ALIGN="LEFT">VARCHAR(50)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="phone" ALIGN="LEFT"><B>phone</B></TD><TD ALIGN="LEFT">VARCHAR(20)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="email" ALIGN="LEFT"><B>email</B></TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="role" ALIGN="LEFT"><B>role</B></TD><TD ALIGN="LEFT">VARCHAR(20)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="total_volunteer_hours" ALIGN="LEFT"><B>total_volunteer_hours</B></TD><TD ALIGN="LEFT">DECIMAL(10,2)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR><TR><TD PORT="status" ALIGN="LEFT"><B>status</B></TD><TD ALIGN="LEFT">TINYINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR><TR><TD PORT="create_time" ALIGN="LEFT"><B>create_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR><TR><TD PORT="update_time" ALIGN="LEFT"><B>update_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR></TABLE>>];
  mq_consume_record [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#6A7A89"><TR><TD BGCOLOR="#24415F" COLSPAN="3"><FONT COLOR="white"><B>mq_consume_record</B></FONT></TD></TR><TR><TD PORT="id" ALIGN="LEFT"><B>id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">PK AI</FONT></TD></TR><TR><TD PORT="message_id" ALIGN="LEFT"><B>message_id</B></TD><TD ALIGN="LEFT">VARCHAR(64)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="consumer_name" ALIGN="LEFT"><B>consumer_name</B></TD><TD ALIGN="LEFT">VARCHAR(120)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="status" ALIGN="LEFT"><B>status</B></TD><TD ALIGN="LEFT">VARCHAR(20)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="consumed_at" ALIGN="LEFT"><B>consumed_at</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR></TABLE>>];
  event_outbox [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#6A7A89"><TR><TD BGCOLOR="#24415F" COLSPAN="3"><FONT COLOR="white"><B>event_outbox</B></FONT></TD></TR><TR><TD PORT="id" ALIGN="LEFT"><B>id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">PK AI</FONT></TD></TR><TR><TD PORT="message_id" ALIGN="LEFT"><B>message_id</B></TD><TD ALIGN="LEFT">VARCHAR(64)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="event_type" ALIGN="LEFT"><B>event_type</B></TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="aggregate_type" ALIGN="LEFT"><B>aggregate_type</B></TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="aggregate_id" ALIGN="LEFT"><B>aggregate_id</B></TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="payload_json" ALIGN="LEFT"><B>payload_json</B></TD><TD ALIGN="LEFT">LONGTEXT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="status" ALIGN="LEFT"><B>status</B></TD><TD ALIGN="LEFT">VARCHAR(20)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="retry_count" ALIGN="LEFT"><B>retry_count</B></TD><TD ALIGN="LEFT">INT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="next_retry_time" ALIGN="LEFT"><B>next_retry_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="created_at" ALIGN="LEFT"><B>created_at</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="sent_at" ALIGN="LEFT"><B>sent_at</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR></TABLE>>];
  user_feedback_projection [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#6A7A89"><TR><TD BGCOLOR="#24415F" COLSPAN="3"><FONT COLOR="white"><B>user_feedback_projection</B></FONT></TD></TR><TR><TD PORT="feedback_id" ALIGN="LEFT"><B>feedback_id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">PK</FONT></TD></TR><TR><TD PORT="user_id" ALIGN="LEFT"><B>user_id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="title" ALIGN="LEFT"><B>title</B></TD><TD ALIGN="LEFT">VARCHAR(200)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="category" ALIGN="LEFT"><B>category</B></TD><TD ALIGN="LEFT">VARCHAR(30)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="status" ALIGN="LEFT"><B>status</B></TD><TD ALIGN="LEFT">VARCHAR(30)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="source_message_id" ALIGN="LEFT"><B>source_message_id</B></TD><TD ALIGN="LEFT">VARCHAR(64)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="created_at" ALIGN="LEFT"><B>created_at</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="updated_at" ALIGN="LEFT"><B>updated_at</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR></TABLE>>];

  user_feedback_projection:user_id -> sys_user:id [label="logical user reference; no DB FK", style="dashed", color="#4F6F52"];
}