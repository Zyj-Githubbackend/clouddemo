digraph ER {
  graph [rankdir=LR, bgcolor=white, pad=0.35, nodesep=0.55, ranksep=0.9, splines=true];
  node [shape=plain, fontname=Arial];
  edge [fontname=Arial, fontsize=10, color="#5D6D7E", arrowsize=0.7];
  labelloc="t";
  label="activity-service";

  vol_activity [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#6A7A89"><TR><TD BGCOLOR="#24415F" COLSPAN="3"><FONT COLOR="white"><B>vol_activity</B></FONT></TD></TR><TR><TD PORT="id" ALIGN="LEFT"><B>id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">PK AI</FONT></TD></TR><TR><TD PORT="title" ALIGN="LEFT"><B>title</B></TD><TD ALIGN="LEFT">VARCHAR(200)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="description" ALIGN="LEFT"><B>description</B></TD><TD ALIGN="LEFT">TEXT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="image_key" ALIGN="LEFT"><B>image_key</B></TD><TD ALIGN="LEFT">TEXT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="location" ALIGN="LEFT"><B>location</B></TD><TD ALIGN="LEFT">VARCHAR(200)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="max_participants" ALIGN="LEFT"><B>max_participants</B></TD><TD ALIGN="LEFT">INT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="current_participants" ALIGN="LEFT"><B>current_participants</B></TD><TD ALIGN="LEFT">INT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="volunteer_hours" ALIGN="LEFT"><B>volunteer_hours</B></TD><TD ALIGN="LEFT">DECIMAL(5,1)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="start_time" ALIGN="LEFT"><B>start_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="end_time" ALIGN="LEFT"><B>end_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="registration_start_time" ALIGN="LEFT"><B>registration_start_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="registration_deadline" ALIGN="LEFT"><B>registration_deadline</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="status" ALIGN="LEFT"><B>status</B></TD><TD ALIGN="LEFT">VARCHAR(20)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="category" ALIGN="LEFT"><B>category</B></TD><TD ALIGN="LEFT">VARCHAR(50)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="creator_id" ALIGN="LEFT"><B>creator_id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="create_time" ALIGN="LEFT"><B>create_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR><TR><TD PORT="update_time" ALIGN="LEFT"><B>update_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR></TABLE>>];
  vol_registration [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#6A7A89"><TR><TD BGCOLOR="#24415F" COLSPAN="3"><FONT COLOR="white"><B>vol_registration</B></FONT></TD></TR><TR><TD PORT="id" ALIGN="LEFT"><B>id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">PK AI</FONT></TD></TR><TR><TD PORT="user_id" ALIGN="LEFT"><B>user_id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="activity_id" ALIGN="LEFT"><B>activity_id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="registration_time" ALIGN="LEFT"><B>registration_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR><TR><TD PORT="check_in_status" ALIGN="LEFT"><B>check_in_status</B></TD><TD ALIGN="LEFT">TINYINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR><TR><TD PORT="check_in_time" ALIGN="LEFT"><B>check_in_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="hours_confirmed" ALIGN="LEFT"><B>hours_confirmed</B></TD><TD ALIGN="LEFT">TINYINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR><TR><TD PORT="confirm_time" ALIGN="LEFT"><B>confirm_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR><TR><TD PORT="status" ALIGN="LEFT"><B>status</B></TD><TD ALIGN="LEFT">VARCHAR(20)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR><TR><TD PORT="create_time" ALIGN="LEFT"><B>create_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR><TR><TD PORT="update_time" ALIGN="LEFT"><B>update_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">DEF</FONT></TD></TR></TABLE>>];
  event_outbox [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#6A7A89"><TR><TD BGCOLOR="#24415F" COLSPAN="3"><FONT COLOR="white"><B>event_outbox</B></FONT></TD></TR><TR><TD PORT="id" ALIGN="LEFT"><B>id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">PK AI</FONT></TD></TR><TR><TD PORT="message_id" ALIGN="LEFT"><B>message_id</B></TD><TD ALIGN="LEFT">VARCHAR(64)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="event_type" ALIGN="LEFT"><B>event_type</B></TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="aggregate_type" ALIGN="LEFT"><B>aggregate_type</B></TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="aggregate_id" ALIGN="LEFT"><B>aggregate_id</B></TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="payload_json" ALIGN="LEFT"><B>payload_json</B></TD><TD ALIGN="LEFT">LONGTEXT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="status" ALIGN="LEFT"><B>status</B></TD><TD ALIGN="LEFT">VARCHAR(20)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="retry_count" ALIGN="LEFT"><B>retry_count</B></TD><TD ALIGN="LEFT">INT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="next_retry_time" ALIGN="LEFT"><B>next_retry_time</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="created_at" ALIGN="LEFT"><B>created_at</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="sent_at" ALIGN="LEFT"><B>sent_at</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR></TABLE>>];
  mq_consume_record [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#6A7A89"><TR><TD BGCOLOR="#24415F" COLSPAN="3"><FONT COLOR="white"><B>mq_consume_record</B></FONT></TD></TR><TR><TD PORT="id" ALIGN="LEFT"><B>id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">PK AI</FONT></TD></TR><TR><TD PORT="message_id" ALIGN="LEFT"><B>message_id</B></TD><TD ALIGN="LEFT">VARCHAR(64)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="consumer_name" ALIGN="LEFT"><B>consumer_name</B></TD><TD ALIGN="LEFT">VARCHAR(120)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN</FONT></TD></TR><TR><TD PORT="status" ALIGN="LEFT"><B>status</B></TD><TD ALIGN="LEFT">VARCHAR(20)</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR><TR><TD PORT="consumed_at" ALIGN="LEFT"><B>consumed_at</B></TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">NN DEF</FONT></TD></TR></TABLE>>];
  external_sys_user [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" COLOR="#6A7A89"><TR><TD BGCOLOR="#24415F" COLSPAN="3"><FONT COLOR="white"><B>external: sys_user</B></FONT></TD></TR><TR><TD PORT="id" ALIGN="LEFT"><B>id</B></TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10">PK</FONT></TD></TR><TR><TD PORT="owned_by" ALIGN="LEFT"><B>owned_by</B></TD><TD ALIGN="LEFT">user-service</TD><TD ALIGN="LEFT"><FONT POINT-SIZE="10"> </FONT></TD></TR></TABLE>>, style="dashed"];

  vol_registration:activity_id -> vol_activity:id [label="registration belongs to activity; no DB FK", style="dashed", color="#4F6F52"];
  vol_registration:user_id -> external_sys_user:id [label="cross-service user id; no DB FK", style="dashed", color="#9A6A2F"];
  vol_activity:creator_id -> external_sys_user:id [label="cross-service creator id; no DB FK", style="dashed", color="#9A6A2F"];
}